# このファイルを .env にコピーし、各値を実環境のものに置き換えてください。
# 起動コマンド: flutter run --dart-define-from-file=.env

# ログイン / サインアップ画面で必須
RESO_API_BASE_URL=https://api.example.com

# Add Spot の場所検索（Google Places）で必須
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Add Spot の画像アップロードで必須（Cloudinary）
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UNSIGNED_UPLOAD_PRESET=your_cloudinary_unsigned_upload_preset